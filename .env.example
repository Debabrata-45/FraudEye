# FraudEye — Root Environment Example
# Copy this to .env and fill in your values

# PostgreSQL
POSTGRES_USER=fraudeye
POSTGRES_PASSWORD=fraudeye_pass
POSTGRES_DB=fraudeye_db

# JWT
JWT_SECRET=change_me_super_secret

# Ports
BACKEND_PORT=4000
ML_SERVICE_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT=5433
REDIS_PORT=6379