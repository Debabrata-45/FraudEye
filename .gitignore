# ================================
# FraudEye — .gitignore
# (final with improvements)
# ================================

# ───────────────────────────────
# Node.js
# ───────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn-integrity

# Keep builds ignored (scoped)
dist/
build/

# ───────────────────────────────
# Environment Variables
# ───────────────────────────────
.env
.env.local
.env.development
.env.production
.env.test
.env*.local

backend/.env
backend/worker/.env
ml-service/.env
infra/.env

# ───────────────────────────────
# Python / ML Service
# ───────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.eggs/
*.egg-info/
*.egg
dist/
*.so
.mypy_cache/
.dmypy.json
dmypy.json
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ML models & data (don’t commit heavy artifacts)
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx
*.model
data/
datasets/
notebooks/.ipynb_checkpoints/

# Optional ML artifacts (only if you create these folders)
ml-service/artifacts/
ml-service/models/
ml-service/runs/

# ───────────────────────────────
# Docker
# ───────────────────────────────
# Don't ignore Dockerfiles or docker-compose.yml
# but ignore override files with secrets
docker-compose.override.yml
docker-compose.local.yml

# ───────────────────────────────
# Redis persistence files
# ───────────────────────────────
dump.rdb
appendonly.aof

# ───────────────────────────────
# Logs
# ───────────────────────────────
logs/
*.log
*.log.*
pids/
*.pid
*.seed
*.pid.lock

# ───────────────────────────────
# VS Code
# ───────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# ───────────────────────────────
# Windows
# ───────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ───────────────────────────────
# React / Frontend
# ───────────────────────────────
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/
.cache/
.parcel-cache/
*.local

# ───────────────────────────────
# Database
# ───────────────────────────────
*.sql.bak
*.dump
pgdata/
postgres-data/

# ───────────────────────────────
# Misc
# ───────────────────────────────
.DS_Store
*.swp
*.swo
*.tmp
*.temp
.idea/
*.iml
coverage/
.nyc_output/